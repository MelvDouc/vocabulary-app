{
  "compilerOptions": {
    "target": "ES2020",
    "lib": [
      "ES2020"
    ],
    "module": "Node16",
    "esModuleInterop": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "server/dist",
    "baseUrl": ".",
    "paths": {
      "$server/*": [
        "./server/src/*"
      ]
    }
  },
  "include": [
    "server"
  ]
}